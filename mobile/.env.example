# MenyAI Mobile – copy to .env
# See ENVIRONMENTS.md in project root for local vs production.
# Do NOT commit .env if it contains secrets.

# Backend API URL (baked in at build time; rebuild after changing)
# Local: leave unset → app uses http://localhost:4000 or http://10.0.2.2:4000 (Android emulator)
# Production/APK: set to your deployed backend URL
EXPO_PUBLIC_API_URL=https://menyai-nslw.onrender.com
