# MenyAI Backend – copy to .env and fill in
# Do NOT commit .env (it's in .gitignore)
# See ENVIRONMENTS.md in project root for a full checklist (local vs Render).

PORT=4000

# Deployed backend URL – used by scripts when BASE_URL is not set.
# On Render: set env vars in Dashboard; this file is for local / script runs.
DEPLOYED_BACKEND_URL=https://menyai-nslw.onrender.com

# Firebase Admin – use ONE of these (local dev). On Render use FIREBASE_SERVICE_ACCOUNT_JSON in Dashboard.
# Option A: path to your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=../menyai-27cfc-firebase-adminsdk-fbsvc-f02c63039e.json

# Option B: paste the one-line JSON (run: node scripts/minify-firebase-json.js "path/to/key.json")
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"menyai-27cfc",...}

# OpenAI – required for AI tutor (MenyAI Umufasha)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Admin panel – X-Admin-Key must match. Use strong secret in production.
# ADMIN_SECRET=your-secure-random-secret
# ADMIN_MOCK=1
